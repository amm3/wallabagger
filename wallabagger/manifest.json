{
   "action": {
      "default_icon": "/img/wallabag-icon-48.png",
      "default_popup": "popup.html",
      "default_title": "Wallabagger",
      "theme_icons": [ {
         "dark": "/img/wallabagger.svg",
         "light": "/img/wallabagger-light.svg",
         "size": 32
      } ]
   },
   "background": {
      "service_worker": "js/background.js",
      "type": "module"
   },
   "commands": {
      "_execute_action": {
         "suggested_key": {
            "default": "Alt+W",
            "mac": "Alt+W",
            "windows": "Alt+W"
         }
      },
      "wallabag-it": {
         "description": "__MSG_Wallabag_it_description__",
         "suggested_key": {
            "default": "Alt+Shift+W",
            "mac": "Alt+Shift+W",
            "windows": "Alt+Shift+W"
         }
      }
   },
   "content_security_policy": {
      "extension_pages": "script-src 'self'"
   },
   "default_locale": "en",
   "description": "__MSG_Extension_description__",
   "icons": {
      "128": "/img/wallabag-icon-128.png",
      "48": "/img/wallabag-icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "minimum_chrome_version": "88",
   "name": "Wallabagger",
   "optional_host_permissions": [ "*://*/api/*", "https://api.openai.com/*", "http://localhost/*", "http://127.0.0.1/*" ],
   "optional_permissions": [ "tabs" ],
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "storage", "contextMenus", "activeTab", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.21.0"
}
